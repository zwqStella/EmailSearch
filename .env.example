# EmailSearch — local config

# Storage / data dir (defaults to ~/.emailsearch)
# EMAILSEARCH_DATA_DIR=
# EMAILSEARCH_DB_PATH=

# Embedding model. Default is multilingual MiniLM (384-dim, ~420 MB, supports
# Chinese / English / 50+ languages). Override carefully — changing dimension
# requires dropping vec_email_chunks (use the Clear button on Settings).
EMAILSEARCH_EMBED_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
EMAILSEARCH_EMBED_DIM=384

# OCR (rapidocr-onnxruntime, ~30 MB ONNX models on first use)
EMAILSEARCH_OCR_ENABLED=true

# Attachment cap (MB) — anything larger is recorded as 'skipped_too_large'
EMAILSEARCH_MAX_ATTACHMENT_MB=25

# Server bind (DO NOT change to 0.0.0.0 — emails are private)
EMAILSEARCH_HOST=127.0.0.1
EMAILSEARCH_PORT=8765
